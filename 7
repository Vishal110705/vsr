DELIMITER //

CREATE PROCEDURE BonusProc()
BEGIN
    DECLARE done INT DEFAULT 0;
    DECLARE id INT;
    DECLARE sal INT;

    DECLARE emp_cursor CURSOR FOR
    SELECT EmpID, Salary FROM Employee;

    DECLARE CONTINUE HANDLER FOR NOT FOUND
    SET done = 1;

    OPEN emp_cursor;

    read_loop: LOOP

        FETCH emp_cursor INTO id, sal;

        IF done = 1 THEN
            LEAVE read_loop;
        END IF;

        UPDATE Employee
        SET Bonus = sal * 10 / 100
        WHERE EmpID = id;

    END LOOP;

    CLOSE emp_cursor;

END //

DELIMITER ;

CALL BonusProc();

